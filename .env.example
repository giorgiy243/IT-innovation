# Скопируй в .env и заполни. .env в git НЕ коммитится.

# --- База данных ---
# Прод: PostgreSQL. Прототип: можно sqlite.
# Формат: postgresql+psycopg://user:password@host:5432/it_innovation
DATABASE_URL=

# --- Окружение ---
# prod | staging | local
APP_ENV=local
# Порт приложения (prod и staging - разные порты)
APP_PORT=8000

# --- Сессии / аутентификация ---
# Секрет для подписи сессий. Сгенерировать случайный, НЕ хранить в репозитории.
SESSION_SECRET=

# --- Мастер-данные ---
# Абсолютный путь к реестру сотрудников (staff.yaml; вне репозитория - ПДн).
STAFF_YAML_PATH=
